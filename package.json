{
  "name": "evolution-api",
  "version": "2.4.0",
  "description": "Rest api for communication with WhatsApp",
  "main": "./dist/main.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc --noEmit && tsup",
    "start": "tsx ./src/main.ts",
    "start:prod": "node --network-family-autoselection-attempt-timeout=1000 dist/main.js",
    "dev:server": "tsx watch ./src/main.ts",
    "test": "tsx watch ./test/all.test.ts",
    "lint": "eslint --fix src",
    "lint:check": "eslint src",
    "commit": "cz",
    "commitlint": "commitlint --edit",
    "db:generate": "node runWithProvider.js \"npx prisma generate --schema ./prisma/DATABASE_PROVIDER-schema.prisma\"",
    "db:deploy": "node runWithProvider.js \"rm -rf ./prisma/migrations && cp -r ./prisma/DATABASE_PROVIDER-migrations ./prisma/migrations && npx prisma migrate deploy --schema ./prisma/DATABASE_PROVIDER-schema.prisma\"",
    "db:deploy:win": "node runWithProvider.js \"xcopy /E /I prisma\\DATABASE_PROVIDER-migrations prisma\\migrations && npx prisma migrate deploy --schema prisma\\DATABASE_PROVIDER-schema.prisma\"",
    "db:studio": "node runWithProvider.js \"npx prisma studio --schema ./prisma/DATABASE_PROVIDER-schema.prisma\"",
    "db:migrate:dev": "node runWithProvider.js \"rm -rf ./prisma/migrations && cp -r ./prisma/DATABASE_PROVIDER-migrations ./prisma/migrations && npx prisma migrate dev --schema ./prisma/DATABASE_PROVIDER-schema.prisma && cp -r ./prisma/migrations/* ./prisma/DATABASE_PROVIDER-migrations\"",
    "db:migrate:dev:win": "node runWithProvider.js \"xcopy /E /I prisma\\DATABASE_PROVIDER-migrations prisma\\migrations && npx prisma migrate dev --schema prisma\\DATABASE_PROVIDER-schema.prisma\"",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EvolutionAPI/evolution-api.git"
  },
  "keywords": [
    "chat",
    "communication",
    "message",
    "send message",
    "whatsapp",
    "js-whatsapp",
    "whatsapp-api",
    "whatsapp-web",
    "whatsapp",
    "whatsapp-chat",
    "whatsapp-group",
    "automation",
    "multi-device",
    "bot"
  ],
  "author": {
    "name": "Davidson Gomes",
    "email": "contato@evolution-api.com"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/EvolutionAPI/evolution-api/issues"
  },
  "homepage": "https://github.com/EvolutionAPI/evolution-api#readme",
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix"
    ],
    "src/**/*.ts": [
      "sh -c 'tsc --noEmit'"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "overrides": {
    "whatsapp-rust-bridge": "0.5.5"
  },
  "dependencies": {
    "@adiwajshing/keyed-db": "^0.2.4",
    "@aws-sdk/client-sqs": "^3.1063.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@figuro/chatwoot-sdk": "^1.1.16",
    "@hapi/boom": "^10.0.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.56.0",
    "@types/uuid": "^10.0.0",
    "amqplib": "^2.0.1",
    "audio-decode": "^2.2.3",
    "axios": "^1.17.0",
    "baileys": "7.0.0-rc13",
    "class-validator": "^0.15.1",
    "compression": "^1.7.5",
    "cors": "^2.8.6",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "emoji-regex": "^10.4.0",
    "eventemitter2": "^6.4.9",
    "express": "^5.2.1",
    "fetch-socks": "^1.3.3",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.1",
    "https-proxy-agent": "^9.0.0",
    "i18next": "^26.3.1",
    "jimp": "^1.6.1",
    "json-schema": "^0.4.0",
    "jsonschema": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "libphonenumber-js": "^1.13.5",
    "link-preview-js": "^3.2.0",
    "long": "^5.2.3",
    "mediainfo.js": "^0.3.7",
    "mime": "^4.0.0",
    "mime-types": "^3.0.2",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nats": "^2.29.1",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "openai": "^6.42.0",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "prisma": "^7.8.0",
    "pusher": "^5.3.3",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "redis": "^6.0.0",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "socks-proxy-agent": "^10.0.0",
    "swagger-ui-express": "^5.0.1",
    "tsup": "^8.3.5",
    "undici": "^8.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/json-schema": "^7.0.15",
    "@types/mime": "^4.0.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^24.13.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/qrcode-terminal": "^0.12.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "patch-package": "^8.0.1",
    "prettier": "^3.8.3",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  }
}
